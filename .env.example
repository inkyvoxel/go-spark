DATABASE_PATH=./data/app.db
APP_ADDR=:8080
# APP_PROCESS can be all, web, or worker. The default all mode runs the
# HTTP server and background jobs worker together for local development.
APP_PROCESS=all
APP_ENV=development
LOG_FORMAT=text
APP_COOKIE_SECURE=false
APP_BASE_URL=http://localhost:8080
# Root signing secret — all per-purpose keys (CSRF, flash, etc.) are derived from this. Required.
# Generate with: openssl rand -hex 32
# Keep secret and outside Git.
SECRET_KEY_BASE=
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_EMAIL_VERIFICATION_REQUIRED=true
AUTH_EMAIL_CHANGE_NOTICE_ENABLED=true
# Password pepper prepended before Argon2id hashing. Required.
# Generate with: openssl rand -hex 32
# Keep secret and outside Git. Rotating this invalidates existing password
# verification until users reset passwords.
AUTH_PASSWORD_PEPPER=
EMAIL_FROM="Go Spark <hello@example.com>"
EMAIL_PROVIDER=log
EMAIL_LOG_BODY=false
JOBS_CLEANUP_INTERVAL=1h
JOBS_CLEANUP_TOKEN_RETENTION=24h
JOBS_CLEANUP_SENT_EMAIL_RETENTION=168h
JOBS_CLEANUP_FAILED_EMAIL_RETENTION=336h

# SMTP settings (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# Trusted reverse proxy IPs (optional, comma-separated IPs or CIDRs).
# Set this when running behind a reverse proxy (Caddy, nginx, Traefik, etc.)
# so rate limiting uses the real client IP from X-Real-IP / X-Forwarded-For.
# Leave blank to use RemoteAddr directly (correct when there is no proxy).
# Example: TRUSTED_PROXY_IPS=127.0.0.1
# Example: TRUSTED_PROXY_IPS=10.0.0.1,172.16.0.0/12
TRUSTED_PROXY_IPS=

# Rate limit overrides (optional)
# Leave blank to use secure defaults from code.
RATE_LIMIT_LOGIN_MAX_REQUESTS=
RATE_LIMIT_LOGIN_WINDOW=
RATE_LIMIT_REGISTER_MAX_REQUESTS=
RATE_LIMIT_REGISTER_WINDOW=
RATE_LIMIT_FORGOT_PASSWORD_MAX_REQUESTS=
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=
RATE_LIMIT_RESET_PASSWORD_MAX_REQUESTS=
RATE_LIMIT_RESET_PASSWORD_WINDOW=
RATE_LIMIT_PUBLIC_RESEND_VERIFICATION_MAX_REQUESTS=
RATE_LIMIT_PUBLIC_RESEND_VERIFICATION_WINDOW=
RATE_LIMIT_ACCOUNT_RESEND_VERIFICATION_MAX_REQUESTS=
RATE_LIMIT_ACCOUNT_RESEND_VERIFICATION_WINDOW=
RATE_LIMIT_CHANGE_PASSWORD_MAX_REQUESTS=
RATE_LIMIT_CHANGE_PASSWORD_WINDOW=
RATE_LIMIT_CHANGE_EMAIL_MAX_REQUESTS=
RATE_LIMIT_CHANGE_EMAIL_WINDOW=
RATE_LIMIT_REVOKE_SESSION_MAX_REQUESTS=
RATE_LIMIT_REVOKE_SESSION_WINDOW=
RATE_LIMIT_REVOKE_OTHER_SESSIONS_MAX_REQUESTS=
RATE_LIMIT_REVOKE_OTHER_SESSIONS_WINDOW=
